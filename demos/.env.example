# LLM Provider: gemini, groq, or local
LLM_PROVIDER=gemini

# Gemini API (get key at https://aistudio.google.com/apikey)
GEMINI_API_KEY=
GEMINI_MODEL=gemini-2.0-flash

# Groq API (get key at https://console.groq.com/keys)
GROQ_API_KEY=
GROQ_MODEL=llama-3.3-70b-versatile

# Local / Ollama (install from https://ollama.com)
LOCAL_BASE_URL=http://localhost:11434
LOCAL_MODEL=llama3

# IPStack API (get key at https://ipstack.com/product)
IPSTACK_ACCESS_KEY=

# Marketstack API (get key at https://marketstack.com/)
MARKETSTACK_ACCESS_KEY=

# Weatherstack API (get key at https://weatherstack.com/)
WEATHERSTACK_ACCESS_KEY=

# Numverify API (get key at https://numverify.com/)
NUMVERIFY_ACCESS_KEY=

# Fixer API (get key at https://fixer.io/)
FIXER_ACCESS_KEY=
