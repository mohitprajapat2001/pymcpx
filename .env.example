# PyMCPX — Root Environment Variables
# Copy to .env and fill in your secrets.
# Each service also has its own .env.example inside its directory.

# ---------------------------------------------------------------------------
# GitHub
# ---------------------------------------------------------------------------
GITHUB_TOKEN=ghp_your_token_here
GITHUB_BASE_URL=https://api.github.com   # Optional: override for GitHub Enterprise

# ---------------------------------------------------------------------------
# Slack
# ---------------------------------------------------------------------------
SLACK_BOT_TOKEN=xoxb-your-bot-token
SLACK_APP_TOKEN=xapp-your-app-token      # Required for socket mode

# ---------------------------------------------------------------------------
# Jira
# ---------------------------------------------------------------------------
JIRA_URL=https://your-org.atlassian.net
JIRA_EMAIL=you@example.com
JIRA_API_TOKEN=your_jira_api_token

# ---------------------------------------------------------------------------
# Gmail
# ---------------------------------------------------------------------------
GMAIL_CREDENTIALS_PATH=credentials.json   # OAuth2 credentials from Google Cloud Console
GMAIL_TOKEN_PATH=token.json               # Generated after first OAuth2 flow

# ---------------------------------------------------------------------------
# Aviationstack
# ---------------------------------------------------------------------------
AVIATIONSTACK_ACCESS_KEY=your_aviationstack_api_key

# ---------------------------------------------------------------------------
# Notion
# ---------------------------------------------------------------------------
NOTION_API_KEY=secret_your_notion_token
